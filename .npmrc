# NPM Configuration for MCP Salesforce Project
# Registry configuration
# Use GitHub Packages registry
@trevsmart:registry=https://npm.pkg.github.com/
registry=https://registry.npmjs.org/

# Package access configuration
access=public

# GitHub Packages authentication
# You need to create a Personal Access Token (PAT) with 'write:packages' scope
# Then run: npm login --scope=@trevSmart --registry=https://npm.pkg.github.com/
# Or set these environment variables:
# NPM_TOKEN=your_github_pat
# NPM_USERNAME=your_github_username
# NPM_EMAIL=your_github_email

# Save exact versions for dependencies
save-exact=true

# Use package-lock.json
package-lock=true

# Engine strict mode
engine-strict=true

# Fund configuration
fund=false

# Audit configuration
audit=false

# Progress bar configuration
progress=false

# Log level
loglevel=warn

# Cache configuration
cache=.npm-cache

# Temporary directory
tmp=.npm-tmp

# Scripts configuration
ignore-scripts=false

# Optional dependencies
optional=false

# Production dependencies only
production=false

# Development dependencies
dev=true

# Peer dependencies
legacy-peer-deps=false

# Workspace configuration
workspaces-update=false
